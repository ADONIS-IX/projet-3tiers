# ──────────────────────────────────────────────────
# Fichier .env.example — NE PAS committer le vrai .env
# Copier ce fichier : cp .env.example .env
# Remplir les valeurs avant de démarrer l'application
# ──────────────────────────────────────────────────

# Serveur Node.js
NODE_ENV=production
PORT=3000
HOST=0.0.0.0
CORS_ORIGIN=*

# Base de donnees MySQL (service interne OpenShift)
DB_HOST=mysql-db.ad-gomis-dev.svc.cluster.local
DB_PORT=3306
DB_NAME=appdb
DB_USER=webuser
DB_PASS=CHANGEZ_CE_MOT_DE_PASSE

# Informations personnelles pour l'interface web (sans DB)
PROFILE_NAME=ADONIS-IX
PROFILE_USERNAME=ad-gomis
PROFILE_EMAIL=adonis@example.com
PROFILE_ROLE=Etudiant
PROFILE_PROJECT=TP Architecture 3-tiers
PROFILE_DATE=31 mars 2026
